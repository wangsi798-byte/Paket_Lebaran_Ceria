# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/sipale
MONGODB_TEST_URI=mongodb://localhost:27017/sipale_test

# JWT Configuration
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=5000
NODE_ENV=development

# SMS OTP Provider
SMS_PROVIDER_API_KEY=your_sms_gateway_api_key
SMS_PROVIDER_URL=https://api.smsprovider.com/send

# File Upload Configuration
UPLOAD_DIR=/uploads
MAX_UPLOAD_SIZE=5242880 # 5MB

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_password

# Lebaran Distribution Settings
DISTRIBUTION_YEAR=2024
DISTRIBUTION_DATE=2024-04-10
BASE_PACKAGE_VALUE=500000