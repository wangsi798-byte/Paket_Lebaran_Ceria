{
  "version": 2,
  "buildCommand": "npm ci --verbose",
  "installCommand": "npm ci --verbose",
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/**",
          "package.json",
          ".npmrc"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    }
  ],
  "env": {
    "NPM_CONFIG_REGISTRY": "https://registry.npmjs.org/",
    "NODE_OPTIONS": "--max_old_space_size=4096"
  }
}